{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureAdB2C": {
    "Authority": "https://example.b2clogin.com/example.onmicrosoft.com/B2C_1_staff_signin/v2.0/",
    "TokenValidationParameters": {
      "ValidAudiences": ["api://thelawyer-api"]
    }
  },
  "Rbac": {
    "RoleAssignments": {
      "attorney":   ["Matters.View", "Matters.Open", "Matters.Edit", "Time.Bill", "Invoices.Draft", "Documents.Edit", "Calendar.Edit", "AiAssistant.Use"],
      "paralegal":  ["Matters.View", "Matters.Edit", "Documents.Edit", "Calendar.Edit", "Invoices.Draft", "AiAssistant.Use"],
      "firm-admin": ["Matters.View", "Matters.Open", "Matters.Edit", "Users.Manage", "Connectors.Manage", "Reports.View", "Tenant.Configure", "Invoices.Approve"],
      "bookkeeper": ["Trust.View", "Trust.Post", "Reconciliation.Manage", "Invoices.View", "Invoices.Approve", "Reports.View"],
      "client":     ["Matter.Self.View", "Invoice.Self.Pay", "Documents.Self.Sign"]
    }
  }
}
