{
  "name": "the-lawyer",
  "industry": "legal",
  "stage": "architecture",
  "cloud": "azure",
  "connectors": [
    "slack",
    "docusign",
    "quickbooks",
    "outlook",
    "dropbox"
  ],
  "capabilities": [
    {
      "name": "vector-db",
      "provider": "pgvector"
    },
    {
      "name": "file-storage",
      "provider": "azure-blob"
    },
    {
      "name": "ocr",
      "provider": "azure-document-intelligence"
    }
  ],
  "github": {
    "repo": "abrahamFerga/the-lawyer",
    "project": 7,
    "visibility": "public"
  },
  "skills": {
    "self": {
      "marketplace": "my-skills",
      "repo": "abrahamFerga/my-skills",
      "plugins": [
        "workflow-core",
        "system-definition",
        "architecture",
        "development"
      ]
    },
    "external": [
      {
        "marketplace": "dotnet/skills",
        "plugins": [
          "dotnet",
          "dotnet-aspnet",
          "dotnet-data",
          "dotnet-ai"
        ],
        "reason": "Authoritative .NET coding-agent skills maintained by the .NET team \u2014 Aspire wiring, ASP.NET Core minimal-API conventions, EF Core migrations, MAF / Azure OpenAI patterns."
      },
      {
        "marketplace": "anthropics/skills",
        "plugins": [
          "pdf",
          "docx"
        ],
        "reason": "Document generation for engagement letters, invoices, court filings, and PDF exports for GDPR data-subject requests."
      }
    ]
  }
}
