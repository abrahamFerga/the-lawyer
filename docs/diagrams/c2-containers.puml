@startuml c2-containers
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title TheLawyer — C4 Level 2: Containers (Cortex-based)

LAYOUT_WITH_LEGEND()

Person(user,  "Staff / Client", "Dev: X-Dev headers; Prod: external IdP (token mode)")
Person(admin, "Firm Admin",     "Cortex admin console")

System_Boundary(thelawyer, "TheLawyer (thin product on Cortex)") {
  Container(apphost, "TheLawyer.AppHost", ".NET 10 Aspire AppHost",              "Orchestrates Postgres, Redis, API; AI provider params (Mock default)")
  Container(host,    "TheLawyer.Host",    "ASP.NET Core + Cortex.AspNetCore",    "AddCortexPlatform() + LegalModule + 4 connectors. Chat (AG-UI/SignalR), admin API, jobs, RAG — all from Cortex packages")
  Container(legal,   "TheLawyer.Legal",   "Cortex.Modules.Sdk module",           "Matters, walls, clause library, playbook, bulk review, matter knowledge, folder sync")
  Container(ui,      "Web UI",            "@cortex/ui + @cortex/admin-ui",       "Chat (AG-UI, drag-drop), module tabs, admin console")
  ContainerDb(pg,    "Postgres",          "pgvector/pgvector:pg17",              "cortex-platform (operational + embeddings) and cortex-audit (append-only)")
  ContainerDb(redis, "Redis",             "Redis 7",                             "Cache / backplane")
}

System_Ext(idp,   "External IdP",       "Entra External ID / B2C (token mode)")
System_Ext(ai,    "AI provider",        "Mock (default) / OpenAI / AzureOpenAI / Ollama via MEAI")
System_Ext(graph, "Microsoft Graph",    "msgraph connector — per-user delegated OAuth")
System_Ext(blob,  "Azure Blob Storage", "azure-blob connector")
System_Ext(peer,  "Peer Cortex system", "cortex-peer connector over AG-UI")

Rel(user,  ui,   "HTTPS")
Rel(admin, ui,   "HTTPS")
Rel(ui,    host, "AG-UI (POST + SSE), SignalR, REST", "HTTPS")

Rel(host, legal, "Hosts as IModule", "in-process")
Rel(host, pg,    "EF Core (platform + module schemas)", "TLS")
Rel(host, redis, "Cache", "TLS")
Rel(host, idp,   "Validates JWT; roles -> permission baselines", "OIDC")
Rel(host, ai,    "MAF agent runs via IChatClient", "HTTPS")
Rel_Bi(host, graph, "Connector tools + sync", "HTTPS")
Rel_Bi(host, blob,  "Connector tools + sync", "HTTPS")
Rel_Bi(host, peer,  "Cross-system agent calls", "AG-UI")

Rel(apphost, host,  "Starts", "Aspire")
Rel(apphost, pg,    "Starts container", "Aspire")
Rel(apphost, redis, "Starts container", "Aspire")

@enduml
