@startuml c3-components-api
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title TheLawyer.Host — C4 Level 3: platform vs module components

LAYOUT_WITH_LEGEND()

Container_Boundary(host, "TheLawyer.Host") {
  Boundary(platform, "Cortex platform (NuGet packages — not in this repo)") {
    Component(auth,   "AuthN/AuthZ",            "Cortex.AspNetCore",     "Dev headers or IdP JWT; token-mode permission source; role -> permission baselines")
    Component(runner, "AuthorizedAgentRunner",  "Cortex.Application",    "MAF agent runs; per-tool RBAC filter; tool-call audit; token usage")
    Component(agui,   "AG-UI + SignalR chat",   "Cortex.AspNetCore",     "POST /api/agui/{module} SSE; hub /hubs/agent")
    Component(rag,    "RAG core",               "Cortex.Infrastructure", "Hybrid pgvector+tsvector (RRF); ingest job; fail-closed collection gates")
    Component(jobs,   "Job runner",             "Cortex.Infrastructure", "Leases, cooperative cancel, max attempts, capability snapshot")
    Component(conn,   "Connector runtime",      "Cortex.Connectors",     "Registry; per-tenant enable; protected secrets; per-user OAuth; bindings; sync")
    Component(files,  "Files + PDF tools",      "Cortex.Infrastructure", "File store; PdfPig read/generate; upload endpoints")
    Component(adminapi, "Admin API",            "Cortex.AspNetCore",     "Security catalog, users/roles, usage, audit, connectors")
  }
  Boundary(module, "TheLawyer.Legal (this repo)") {
    Component(legalmod, "LegalModule",       "IModule v1.3.0",  "Manifest, tabs, 13 agent tools")
    Component(tools,    "MatterTools etc.",  "IModuleToolSource", "Matters, walls, clause library, playbook, bulk review")
    Component(gate,     "MatterRagGate",     "IRagCollectionGate", "Matter knowledge respects ethical walls (fail-closed)")
    Component(sync,     "MatterSyncHandler", "connector sync handler", "Folder sync -> matter documents -> RAG ingest")
    Component(db,       "LegalDbContext",    "EF Core + migrations", "Matter, Party, MatterWall, ClauseLibraryEntry, PlaybookRule")
  }
}

Rel(agui, runner, "Runs the legal agent")
Rel(runner, tools, "Dispatches permitted tools")
Rel(runner, conn,  "Connector tools (if tenant-enabled)")
Rel(tools, db,     "EF Core")
Rel(rag, gate,     "Access check per collection")
Rel(sync, rag,     "Enqueues rag-ingest")
Rel(conn, sync,    "Sync job per binding")
Rel(jobs, rag,     "platform.rag-ingest")
Rel(auth, runner,  "Capability set")

@enduml
