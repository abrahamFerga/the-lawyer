# Copy to http/.env (gitignored) or let scripts/run-and-wait.ps1 write it.
# NO real secrets here — only test values.

# Base URL of the running API. run-and-wait.ps1 overwrites this with the
# Aspire-assigned port each run.
API_BASE=http://localhost:5080

# Test OIDC bearer token for authed endpoints (lands with later epics).
# Generate from a TEST identity — never paste a real token.
TOKEN=

# Test tenant id for the X-Tenant-Id header.
TENANT_ID=00000000-0000-0000-0000-000000000000
